    {
      "cell_type": "code",
      "execution_count": 65,
      "id": "095a70a1",
      "metadata": {
        "id": "095a70a1",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "82d821ac-b433-4810-f76e-b2894f6da839"
