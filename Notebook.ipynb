      "source": [
        "for file_info in zf.infolist():\n",
        "    filename = file_info.filename.lower()\n",
        "\n",
        "    if not (filename.endswith('.md') or filename.endswith('.mdx')):\n",
        "        continue\n",
        "\n",
        "    # rest remains the same...\n"
